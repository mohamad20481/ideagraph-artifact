# Copy this file to .env and fill in your values.
# NEVER commit the real .env — it contains secrets.

# ── Active LLM provider + model ──────────────────────────────────────────────
# One of: deepseek | openai | groq | gemini | azure | anthropic | kimi | xai
# (xai = api.x.ai endpoint, hosts Grok + DeepSeek V4. Distinct from groq.)
IDEAGRAPH_PROVIDER=deepseek
IDEAGRAPH_MODEL=deepseek-chat

# ── LLM provider API keys ────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AZURE_BASE_URL=https://your-resource.services.ai.azure.com/models
# KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# KIMI_BASE_URL=https://api.moonshot.ai/v1

# Native Anthropic Claude (via /v1/messages with prompt caching)
# Default base URL is api.anthropic.com. Override for a proxy.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# xAI Grok (LLM via api.x.ai/v1) + image generation (NANO_BANANA_PROVIDER=grok).
# Same xAI account key works for both surfaces. Key format: xai-...
# XAI_BASE_URL=https://api.x.ai/v1
# GROK_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # fallback alias

# ── Admin gate ───────────────────────────────────────────────────────────────
# Comma-separated user IDs with admin dashboard access.
ADMIN_USER_IDS=

# ── Optional external tools ──────────────────────────────────────────────────
# SEMANTIC_SCHOLAR_API_KEY=

# ── Visual rendering (🎨 Visual Abstract panel) ──────────────────────────────
# Provider options: flux_bfl | gemini_imagen | gemini_flash_image | veo | grok
NANO_BANANA_PROVIDER=flux_bfl
# Key from https://api.bfl.ml (flux_bfl) / https://aistudio.google.com/apikey (gemini_*)
# / GROK_API_KEY (grok image)
NANO_BANANA_API_KEY=
# NANO_BANANA_MODEL=  # provider default if blank
# NANO_BANANA_ENDPOINT=  # provider default if blank
IDEAGRAPH_VISUAL_RENDERING=true

# ── Stripe (billing) ─────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys (test mode) or /apikeys (live)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_WEBHOOK_SECRET=
# Create products in Stripe Dashboard and paste the resulting price_... IDs
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_ENTERPRISE=
APP_BASE_URL=http://localhost:8510

# ── Production hardening ─────────────────────────────────────────────────────
# Comma-separated CORS origins for the FastAPI endpoint.
API_ALLOWED_ORIGINS=http://localhost:8510,http://localhost:3000
# Set to enforce bearer auth on /api/run; leave empty for dev mode.
API_BEARER_TOKEN=
API_RUN_RETENTION_S=3600
API_RUN_MAX_ENTRIES=10000

# Rate limiter (per-user sliding window + burst bucket).
RL_USER_LIMIT=60
RL_USER_WINDOW=60
RL_IP_LIMIT=30
RL_IP_WINDOW=60

# Circuit breaker for LLM providers.
CB_THRESHOLD=5
CB_RECOVERY_S=60

# Concurrency caps (protects against thread exhaustion).
CG_GLOBAL_MAX=100
CG_PER_USER_MAX=3

# ── Pipeline speed / cost settings ────────────────────────────────────────────
MAX_NODES=20
DEPTH=2
SEEDS=5
SEED_QUERIES=3
MAX_ITERATIONS=10
COVERAGE_THRESHOLD=0.4
IDEAGRAPH_CORPUS_ANCHORED_NOVELTY=true
